<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pakgopay.mapper.AccountEventMapper">

    <resultMap id="AccountEventResultMap" type="com.pakgopay.mapper.dto.AccountEventDto">
        <id column="id" property="id" javaType="java.lang.Long"/>
        <result column="event_type" property="eventType" javaType="java.lang.String"/>
        <result column="biz_no" property="bizNo" javaType="java.lang.String"/>
        <result column="user_id" property="userId" javaType="java.lang.String"/>
        <result column="currency" property="currency" javaType="java.lang.String"/>
        <result column="amount" property="amount" javaType="java.math.BigDecimal"/>
        <result column="event_time" property="eventTime" javaType="java.lang.Long"/>
        <result column="status" property="status" javaType="java.lang.Short"/>
        <result column="retry_count" property="retryCount" javaType="java.lang.Integer"/>
        <result column="batch_no" property="batchNo" javaType="java.lang.String"/>
        <result column="last_error" property="lastError" javaType="java.lang.String"/>
        <result column="created_at" property="createdAt" javaType="java.lang.Long"/>
        <result column="updated_at" property="updatedAt" javaType="java.lang.Long"/>
    </resultMap>

    <resultMap id="AccountEventQueryResultMap" type="com.pakgopay.mapper.dto.AccountEventQueryDto">
        <result column="user_name" property="userName" javaType="java.lang.String"/>
        <result column="role_id" property="roleId" javaType="java.lang.Integer"/>
        <result column="currency" property="currency" javaType="java.lang.String"/>
        <result column="amount" property="amount" javaType="java.math.BigDecimal"/>
        <result column="event_type" property="eventType" javaType="java.lang.String"/>
        <result column="created_at" property="createTime" javaType="java.lang.Long"/>
        <result column="updated_at" property="updateTime" javaType="java.lang.Long"/>
    </resultMap>

    <insert id="insertEventBatch">
        INSERT INTO ${tableName} (
            event_type,
            biz_no,
            user_id,
            currency,
            amount,
            event_time,
            status,
            retry_count,
            created_at,
            updated_at
        )
        VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.eventType},
                #{item.bizNo},
                #{item.userId},
                #{item.currency},
                #{item.amount},
                #{item.eventTime},
                #{item.status},
                #{item.retryCount},
                #{item.createdAt},
                #{item.updatedAt}
            )
        </foreach>
    </insert>

    <select id="claimPendingEventsFromTable" resultMap="AccountEventResultMap">
        SELECT
            id,
            event_type,
            biz_no,
            user_id,
            currency,
            amount,
            event_time,
            status,
            retry_count,
            batch_no,
            last_error,
            created_at,
            updated_at
        FROM ${tableName}
        WHERE status IN (1, 3)
          AND event_type IN
            <foreach collection="eventTypes" item="eventType" open="(" close=")" separator=",">
                #{eventType}
            </foreach>
        ORDER BY event_time ASC, id ASC
        LIMIT #{limitSize}
    </select>

    <select id="listByTransactionNo" resultMap="AccountEventQueryResultMap">
        SELECT
            u.login_name AS user_name,
            u.role_id,
            e.currency,
            e.amount,
            e.event_type,
            e.status,
            e.created_at,
            e.updated_at
        FROM account_event e
        LEFT JOIN user_info u ON u.user_id = e.user_id
        WHERE e.biz_no LIKE concat(#{transactionNo}, '%')
          AND e.created_at <![CDATA[ >= ]]> #{partitionStart}
          AND e.created_at <![CDATA[ < ]]> #{partitionEnd}
        ORDER BY e.event_time ASC, e.id ASC
    </select>

    <update id="markDoneByIds">
        UPDATE account_event
        SET status = 2,
            batch_no = #{batchNo},
            last_error = NULL,
            updated_at = #{now}
        WHERE status IN (1, 3)
          AND created_at <![CDATA[ >= ]]> #{partitionStart}
          AND created_at <![CDATA[ < ]]> #{partitionEnd}
        <choose>
            <when test="ids != null and ids.size() > 0">
              AND id IN
                <foreach collection="ids" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </when>
            <otherwise>
              AND 1 = 0
            </otherwise>
        </choose>
    </update>

    <update id="markFailedByIds">
        UPDATE account_event
        SET status = 3,
            retry_count = retry_count + 1,
            last_error = #{error},
            updated_at = #{now}
        WHERE status IN (1, 3)
          AND created_at <![CDATA[ >= ]]> #{partitionStart}
          AND created_at <![CDATA[ < ]]> #{partitionEnd}
        <choose>
            <when test="ids != null and ids.size() > 0">
              AND id IN
                <foreach collection="ids" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </when>
            <otherwise>
              AND 1 = 0
            </otherwise>
        </choose>
    </update>

</mapper>
