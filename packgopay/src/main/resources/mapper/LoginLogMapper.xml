<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pakgopay.mapper.LoginLogMapper">

    <resultMap id="LoginLogResultMap" type="com.pakgopay.mapper.dto.LoginLogDto">
        <id column="id" property="id" javaType="java.lang.Long"/>
        <id column="user_id" property="userId" javaType="java.lang.String"/>
        <result column="login_name" property="loginName" javaType="java.lang.String"/>
        <result column="login_role" property="loginRole" javaType="java.lang.String"/>
        <result column="login_ip" property="loginIp" javaType="java.lang.String"/>
        <result column="create_time" property="createTime" javaType="java.lang.Long"/>
        <result column="update_time" property="updateTime" javaType="java.lang.Long"/>
        <result column="event_type" property="eventType" javaType="java.lang.Integer"/>
        <result column="event_time" property="eventTime" javaType="java.lang.Long"/>
        <result column="token_jti" property="tokenJti" javaType="java.lang.String"/>
        <result column="logout_reason" property="logoutReason" javaType="java.lang.String"/>
    </resultMap>

    <sql id="BaseColumns">
        id,
        user_id,
        login_name,
        login_role,
        login_ip,
        create_time,
        update_time,
        event_type,
        event_time,
        token_jti,
        logout_reason
    </sql>

    <insert id="insert" parameterType="com.pakgopay.mapper.dto.LoginLogDto">
        INSERT INTO login_log (
            user_id,
            login_name,
            login_role,
            login_ip,
            create_time,
            update_time,
            event_type,
            event_time,
            token_jti,
            logout_reason
        ) VALUES (
            #{userId},
            #{loginName},
            #{loginRole},
            #{loginIp},
            #{createTime},
            #{updateTime},
            #{eventType},
            #{eventTime},
            #{tokenJti},
            #{logoutReason}
        )
    </insert>

    <select id="findById" resultMap="LoginLogResultMap">
        SELECT
            <include refid="BaseColumns"/>
        FROM login_log
        WHERE id = #{id}
          AND user_id = #{userId}
        LIMIT 1
    </select>

    <select id="listByUserId" resultMap="LoginLogResultMap">
        SELECT
            <include refid="BaseColumns"/>
        FROM login_log
        WHERE user_id = #{userId}
        ORDER BY event_time DESC, create_time DESC
    </select>

    <select id="countByTokenJtiAndEventType" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM login_log
        WHERE token_jti = #{tokenJti}
          AND event_type = #{eventType}
    </select>

    <sql id="LoginLogWhere">
        <where>
            <if test="loginName != null and loginName != ''">
                AND login_name = #{loginName}
            </if>
            <if test="startTime != null">
                AND event_time &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND event_time &lt;= #{endTime}
            </if>
        </where>
    </sql>

    <select id="countByQuery" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM login_log
        <include refid="LoginLogWhere"/>
    </select>

    <select id="pageByQuery" resultMap="LoginLogResultMap">
        SELECT
            id,
            user_id,
            login_name,
            login_role,
            login_ip,
            create_time,
            update_time,
            event_type,
            event_time,
            logout_reason
        FROM login_log
        <include refid="LoginLogWhere"/>
        ORDER BY event_time DESC, create_time DESC, id DESC
        LIMIT #{pageSize} OFFSET #{offSet}
    </select>

</mapper>
